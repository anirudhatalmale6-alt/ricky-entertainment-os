# Production env for the cPanel/Passenger deploy at reenewtv.com/ricky
# Copy to .env in the application root and fill SECRET_KEY with a long random value.

# Served under a sub-path -> both the frontend API base and FastAPI root_path.
ROOT_PATH=/ricky

# SQLite keeps the staging deploy dependency-free. Absolute path so it does not
# depend on Passenger's working directory (replace <user> with the cPanel user).
DATABASE_URL=sqlite+aiosqlite:////home/<user>/ricky_app/ricky.db

SECRET_KEY=replace-with-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ENVIRONMENT=production

TOTP_ISSUER=RICKY Entertainment OS
CORS_ORIGINS=*
