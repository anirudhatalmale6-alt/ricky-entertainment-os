# Copy to .env and adjust for your environment.

# SQLite (default, dev):
DATABASE_URL=sqlite+aiosqlite:///./ricky.db
# PostgreSQL (prod):
# DATABASE_URL=postgresql+asyncpg://ricky:password@localhost:5432/ricky_os

SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ENVIRONMENT=development

TOTP_ISSUER=RICKY Entertainment OS
CORS_ORIGINS=*
